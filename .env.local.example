# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and must never be committed.

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL and keys from your Supabase project settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key bypasses row-level security; required by scripts/classify.ts
# to write holder_classifications and holder_aggregate_stats. Keep it secret —
# never expose it in client code or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# ── Etherscan ───────────────────────────────────────────────────────────────
# API key for supply, holders, and transfer history.
ETHERSCAN_API_KEY=

# ── Dune (optional, for supply/AUM history queries) ─────────────────────────
# Only needed if you run Dune-backed scripts locally.
DUNE_API_KEY=
